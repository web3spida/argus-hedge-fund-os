# Required for RainbowKit / WalletConnect wallet connections.
# Create a project at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional public deployment metadata.
VITE_APP_NAME=Argus
VITE_APP_ENV=production

# Future backend/API configuration.
# Do not expose private API keys with the VITE_ prefix.
# Keep SoSoValue, SoDEX, Gemini, and signing secrets server-side only.

# Example future public API base URL if a backend proxy is deployed:
# VITE_API_BASE_URL=https://your-api.example.com
